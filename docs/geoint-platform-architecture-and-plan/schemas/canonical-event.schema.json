{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/canonical-event.schema.json",
  "title": "CanonicalEvent",
  "type": "object",
  "required": [
    "event_id",
    "source",
    "source_type",
    "entity_type",
    "event_type",
    "event_time",
    "geometry",
    "centroid",
    "attributes",
    "normalization",
    "provenance",
    "ingested_at",
    "license"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "entity_type": {
      "type": "string"
    },
    "entity_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_type": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "time_start": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "time_end": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "geometry": {
      "type": "object"
    },
    "centroid": {
      "type": "object"
    },
    "altitude_m": {
      "type": [
        "number",
        "null"
      ]
    },
    "depth_m": {
      "type": [
        "number",
        "null"
      ]
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attributes": {
      "type": "object"
    },
    "normalization": {
      "type": "object",
      "required": [
        "schema_version",
        "normalized_by",
        "normalization_warnings"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "normalized_by": {
          "type": "string"
        },
        "normalization_warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dedupe_key": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "raw_source_ref"
      ],
      "properties": {
        "raw_source_ref": {
          "type": "string"
        },
        "source_record_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_record_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "first_seen_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_seen_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "correlation_keys": {
      "type": "object"
    },
    "license": {
      "type": "object",
      "required": [
        "access_tier",
        "commercial_use",
        "redistribution",
        "attribution_required"
      ],
      "properties": {
        "access_tier": {
          "type": "string"
        },
        "commercial_use": {
          "type": "string"
        },
        "redistribution": {
          "type": "string"
        },
        "attribution_required": {
          "type": "boolean"
        }
      }
    }
  }
}