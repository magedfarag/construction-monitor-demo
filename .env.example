# ============================================================
# ARGUS — Multi-Domain Surveillance Intelligence — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.
# Do NOT commit your .env file to source control.
# ============================================================

# ── App Mode ────────────────────────────────────────────────
# demo     : always use DemoProvider (deterministic test data, no credentials needed)
# staging  : use real providers (Sentinel-2, Landsat) with automatic demo fallback (default, safe for dev)
# production : use real providers only (fail-fast if unavailable, no demo fallback)
APP_MODE=staging

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to "json" for structured JSON logs (recommended for production).
# Set to "text" for human-readable console output.
LOG_FORMAT=json

# ── Sentinel-2 (Copernicus Data Space Ecosystem) ────────────
# Register at https://dataspace.copernicus.eu to get credentials.
# Required for live Sentinel-2 imagery access via CDSE.
SENTINEL2_CLIENT_ID=
SENTINEL2_CLIENT_SECRET=
# Optional: override default token and search endpoints
# SENTINEL2_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
# SENTINEL2_STAC_URL=https://catalogue.dataspace.copernicus.eu/stac/v1
#
# ── Element84 Earth Search (recommended for public COG access) ──
# Switching to Element84 removes the need for Copernicus credentials.
# COGs are hosted on public S3 — band reads, change detection, and
# thumbnails all work without auth. Uncomment to use:
SENTINEL2_STAC_URL=https://earth-search.aws.element84.com/v1

# ── Landsat (USGS LandsatLook STAC) ─────────────────────────
# STAC search for Landsat is publicly accessible without credentials.
# Credentials are only needed for M2M bulk download (optional).
# Register at https://ers.cr.usgs.gov if you need M2M access.
LANDSAT_USERNAME=
LANDSAT_PASSWORD=
# Optional: override default STAC endpoint
# LANDSAT_STAC_URL=https://landsatlook.usgs.gov/stac-server

# ── Maxar (SecureWatch / Open Data) ─────────────────────────
# Commercial high-resolution imagery (0.3-0.5 m).
# Requires a SecureWatch subscription: https://www.maxar.com/products/securewatch
MAXAR_API_KEY=
# Optional: override default STAC endpoint
# MAXAR_STAC_URL=https://api.maxar.com/discovery/v1

# ── Planet (PlanetScope / SkySat) ────────────────────────────
# Commercial daily-revisit imagery (3-5 m PlanetScope, 0.5 m SkySat).
# Requires a Planet API key: https://www.planet.com/
PLANET_API_KEY=
# Optional: override default API endpoint
# PLANET_API_URL=https://api.planet.com/data/v1

# ── Redis ───────────────────────────────────────────────────
# Required for: Celery broker + result backend, distributed caching,
# circuit breaker state, and job persistence.
# If not set: async jobs are unavailable; in-memory cache is used.
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ──────────────────────────────────────────────
# Optional: persistent job history.  If not set, jobs are stored in
# Redis (with 24h TTL) or in-memory only.
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/argus_intel

# ── Celery ──────────────────────────────────────────────────
# Uses REDIS_URL by default. Override below if needed.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Cache ───────────────────────────────────────────────────
# TTL in seconds for cached analysis results (default: 1 hour)
CACHE_TTL_SECONDS=3600
# Maximum entries for the in-memory fallback cache (used when Redis is unavailable)
CACHE_MAX_ENTRIES=256

# ════════════════════════════════════════════════════════════
# V2 Geospatial Intelligence Platform — Additional Variables
# (P0-2.5: merged from docs/geoint-platform-architecture-and-plan/config/example.env)
# ════════════════════════════════════════════════════════════

# ── Object Storage (MinIO for local dev; S3-compatible for production) ──────
# Required to store raw ingested payloads and export artefacts.
# Set up MinIO locally: docker run -p 9000:9000 -p 9001:9001 minio/minio server /data
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=geoint-raw
OBJECT_STORAGE_ACCESS_KEY=change-me
OBJECT_STORAGE_SECRET_KEY=change-me

# ── AISStream (Maritime AIS tracking) ───────────────────────────────────────
# Free API key at https://aisstream.io — WebSocket feed, ME coverage: Yes
# Required for Phase 3 maritime layer. Leave empty to disable AIS connector.
AISSTREAM_API_KEY=
# AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream

# ── OpenSky Network (Aviation ADS-B) ────────────────────────────────────────
# Non-commercial use only (check https://opensky-network.org/about/terms-of-use).
# Register at https://opensky-network.org/index.php?option=com_user&view=registration
# Required for Phase 3 aviation layer. Leave empty to disable aviation connector.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# OPENSKY_API_URL=https://opensky-network.org/api

# ── GDELT 2.0 (Contextual news/event feed) ──────────────────────────────────
# No authentication required — truly free/public, ME coverage: Yes.
# Used in Phase 2 for contextual event correlation.
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2

# ── Earth Search / Planetary Computer STAC (Phase 1 additional catalogs) ────
# EARTH_SEARCH_STAC_URL=https://earth-search.aws.element84.com/v1
# PLANETARY_COMPUTER_STAC_URL=https://planetarycomputer.microsoft.com/api/stac/v1
# PLANETARY_COMPUTER_TOKEN=   # optional subscription key for higher rate limits

# ── HTTP Client ─────────────────────────────────────────────
# Timeout in seconds for external provider requests
HTTP_TIMEOUT_SECONDS=30
# Maximum retry attempts for transient provider errors
HTTP_MAX_RETRIES=3

# ── Circuit Breaker ─────────────────────────────────────────
# Number of consecutive failures before opening a circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# Seconds to wait before attempting recovery (half-open state)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ── Analysis Pipeline ───────────────────────────────────────
# Maximum cloud cover percentage to accept a scene (0–100)
DEFAULT_CLOUD_THRESHOLD=20
# AOI area threshold (km²) above which analysis is forced to async
ASYNC_AREA_THRESHOLD_KM2=25
# Temporary directory for downloaded raster assets (default: system temp)
# RASTER_TEMP_DIR=/tmp/argus-intel

# ── Security ────────────────────────────────────────────────
# CORS: Comma-separated list of allowed origins.
# Default (dev): http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
# For production, set to the exact frontend domain(s).
# Example: https://mysite.com,https://www.mysite.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# API Key for authentication (Bearer token, ?api_key query, or api_key cookie).
# If empty: authentication is disabled (insecure development mode).
# For production: set to a strong random value.
#   Linux/macOS: openssl rand -hex 32
#   Windows (PowerShell): [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# Routes requiring authentication: POST /api/analyze, POST /api/search, DELETE /api/jobs/{id}/cancel
API_KEY=
