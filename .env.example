# ============================================================
# ARGUS — Multi-Domain Surveillance Intelligence — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Lines starting with # are comments.
# Do NOT commit your .env file to source control.
# ============================================================

# ── App Mode ────────────────────────────────────────────────
# demo     : always use DemoProvider (deterministic test data, no credentials needed)
# staging  : use real providers (Sentinel-2, Landsat) with automatic demo fallback (default, safe for dev)
# production : use real providers only (fail-fast if unavailable, no demo fallback)
APP_MODE=production

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to "json" for structured JSON logs (recommended for production).
# Set to "text" for human-readable console output.
LOG_FORMAT=json

# ── Sentinel-2 (Copernicus Data Space Ecosystem) ────────────
# Register at https://dataspace.copernicus.eu to get credentials.
# Required for live Sentinel-2 imagery access via CDSE.
SENTINEL2_CLIENT_ID=
SENTINEL2_CLIENT_SECRET=
# Optional: override default token and search endpoints
# SENTINEL2_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
# SENTINEL2_STAC_URL=https://stac.dataspace.copernicus.eu/v1
#
# ── Element84 Earth Search (recommended for public COG access) ──
# Switching to Element84 removes the need for Copernicus credentials.
# COGs are hosted on public S3 — band reads, change detection, and
# thumbnails all work without auth. Uncomment to use:
SENTINEL2_STAC_URL=https://earth-search.aws.element84.com/v1

# ── Landsat (USGS LandsatLook STAC) ─────────────────────────
# STAC search for Landsat is publicly accessible without credentials.
# Credentials are only needed for M2M bulk download (optional).
# Register at https://ers.cr.usgs.gov if you need M2M access.
LANDSAT_USERNAME=
LANDSAT_PASSWORD=
# Optional: override default STAC endpoint
# LANDSAT_STAC_URL=https://landsatlook.usgs.gov/stac-server

# ── Maxar (SecureWatch / Open Data) ─────────────────────────
# Commercial high-resolution imagery (0.3-0.5 m).
# Requires a SecureWatch subscription: https://www.maxar.com/products/securewatch
MAXAR_API_KEY=
# Optional: override default STAC endpoint
# MAXAR_STAC_URL=https://api.maxar.com/discovery/v1

# ── Planet (PlanetScope / SkySat) ────────────────────────────
# Commercial daily-revisit imagery (3-5 m PlanetScope, 0.5 m SkySat).
# Requires a Planet API key: https://www.planet.com/
PLANET_API_KEY=
# Optional: override default API endpoint
# PLANET_API_URL=https://api.planet.com/data/v1

# ── Redis ───────────────────────────────────────────────────
# Required for: Celery broker + result backend, distributed caching,
# circuit breaker state, and job persistence.
# If not set: async jobs are unavailable; in-memory cache is used.
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ──────────────────────────────────────────────
# Optional: persistent job history.  If not set, jobs are stored in
# Redis (with 24h TTL) or in-memory only.
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/argus_intel

# ── Celery ──────────────────────────────────────────────────
# Uses REDIS_URL by default. Override below if needed.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Cache ───────────────────────────────────────────────────
# TTL in seconds for cached analysis results (default: 1 hour)
CACHE_TTL_SECONDS=3600
# Maximum entries for the in-memory fallback cache (used when Redis is unavailable)
CACHE_MAX_ENTRIES=256

# ════════════════════════════════════════════════════════════
# V2 Geospatial Intelligence Platform — Additional Variables
# (P0-2.5: merged from docs/geoint-platform-architecture-and-plan/config/example.env)
# ════════════════════════════════════════════════════════════

# ── Object Storage (MinIO for local dev; S3-compatible for production) ──────
# Required to store raw ingested payloads and export artefacts.
# Set up MinIO locally: docker run -p 9000:9000 -p 9001:9001 minio/minio server /data
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=geoint-raw
OBJECT_STORAGE_ACCESS_KEY=change-me
OBJECT_STORAGE_SECRET_KEY=change-me

# ── CelesTrak GP (Active Satellite TLEs) ──────────────────────────────────
# Open data, no registration required: https://celestrak.org/
# connector_id: celestrak-gp-live  |  src/connectors/celestrak_connector.py
# Timeout in seconds for CelesTrak GP fetches. Default: 30.
CELESTRAK_FETCH_TIMEOUT_SEC=30

# ── FAA NOTAM Search API ─────────────────────────────────────────────────────
# Free API key required. Register at https://api.faa.gov/
# connector_id: faa-notam-live  |  src/connectors/faa_notam_connector.py
# Without this key, the airspace lane falls back to the demo stub.
FAA_NOTAM_CLIENT_ID=

# ── AISStream (Maritime AIS tracking) ───────────────────────────────────────
# Free API key at https://aisstream.io — WebSocket feed, ME coverage: Yes
# Required for Phase 3 maritime layer. Leave empty to disable AIS connector.
AISSTREAM_API_KEY=
# AISSTREAM_WS_URL=wss://stream.aisstream.io/v0/stream

# ── OpenSky Network (Aviation ADS-B) ────────────────────────────────────────
# Non-commercial use only (check https://opensky-network.org/about/terms-of-use).
# Register at https://opensky-network.org/index.php?option=com_user&view=registration
# Required for Phase 3 aviation layer. Leave empty to disable aviation connector.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# OPENSKY_API_URL=https://opensky-network.org/api

# ── GDELT 2.0 (Contextual news/event feed) ──────────────────────────────────
# No authentication required — truly free/public, ME coverage: Yes.
# Used in Phase 2 for contextual event correlation.
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2

# ── Earth Search / Planetary Computer STAC (Phase 1 additional catalogs) ────
# EARTH_SEARCH_STAC_URL=https://earth-search.aws.element84.com/v1
# PLANETARY_COMPUTER_STAC_URL=https://planetarycomputer.microsoft.com/api/stac/v1
# PLANETARY_COMPUTER_TOKEN=   # optional subscription key for higher rate limits

# ── HTTP Client ─────────────────────────────────────────────
# Timeout in seconds for external provider requests
HTTP_TIMEOUT_SECONDS=30
# Maximum retry attempts for transient provider errors
HTTP_MAX_RETRIES=3

# ── Circuit Breaker ─────────────────────────────────────────
# Number of consecutive failures before opening a circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# Seconds to wait before attempting recovery (half-open state)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# ── Analysis Pipeline ───────────────────────────────────────
# Maximum cloud cover percentage to accept a scene (0–100)
DEFAULT_CLOUD_THRESHOLD=20
# AOI area threshold (km²) above which analysis is forced to async
ASYNC_AREA_THRESHOLD_KM2=25
# Temporary directory for downloaded raster assets (default: system temp)
# RASTER_TEMP_DIR=/tmp/argus-intel

# ── Security ────────────────────────────────────────────────
# CORS: Comma-separated list of allowed origins.
# Default (dev): http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000
# For production, set to the exact frontend domain(s).
# Example: https://mysite.com,https://www.mysite.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# API Key for authentication (Bearer token, ?api_key query, or api_key cookie).
# If empty: authentication is disabled (insecure development mode).
# For production: set to a strong random value.
#   Linux/macOS: openssl rand -hex 32
#   Windows (PowerShell): [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# Routes requiring authentication: POST /api/analyze, POST /api/search, DELETE /api/jobs/{id}/cancel
API_KEY=

# ── Phase 6 RBAC ────────────────────────────────────────────
# JWT secret for HMAC-SHA256 role tokens.
# Must be at least 32 characters of entropy in production.
#   Linux/macOS: openssl rand -hex 32
#   Windows (PowerShell): [Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=

# Role-scoped API keys — each must be a distinct high-entropy value in production.
ADMIN_API_KEY=
OPERATOR_API_KEY=
ANALYST_API_KEY=

# ── Phase 6 Cost Guardrails ─────────────────────────────────
# Prevent resource exhaustion from briefing/export abuse (0 = unlimited).
MAX_BRIEFINGS_PER_HOUR_PER_USER=10
MAX_EVIDENCE_PACKS_PER_HOUR_PER_USER=20
MAX_EXPORT_SIZE_MB=50

# ════════════════════════════════════════════════════════════
# Additional Data Sources (Phase 2+)
# ════════════════════════════════════════════════════════════

# ── ACLED (Armed Conflict Location & Event Data) ───────────
# Register via myACLED: https://acleddata.com/user/register
# IMPORTANT: Access is governed by the myACLED system (https://acleddata.com/myacled-faqs).
# Non-commercial research: free with registration.
# Commercial, competitive, or AI/ML use: requires explicit written agreement with ACLED.
# Re-verify the onboarding flow and usage restrictions before any production deployment.
# The OAuth2 token URL below was active at last verification; confirm it is still correct.
ACLED_EMAIL=
ACLED_PASSWORD=
# Optional: override default endpoints
# ACLED_TOKEN_URL=https://acleddata.com/oauth/token
# ACLED_API_URL=https://acleddata.com/api/acled/read

# ── NASA FIRMS (Active Fire / Thermal Anomaly) ─────────────
# Free MAP_KEY at https://firms.modaps.eosdis.nasa.gov/api/
# Use "DEMO_KEY" for testing (rate-limited); register for higher limits.
NASA_FIRMS_MAP_KEY=DEMO_KEY
# Data source product (VIIRS_SNPP_NRT, VIIRS_NOAA20_NRT, VIIRS_NOAA21_NRT, MODIS_NRT, MODIS_SP)
NASA_FIRMS_SOURCE=VIIRS_SNPP_NRT
# Days of archive to query (1–10)
NASA_FIRMS_DAYS_LOOKBACK=2
# Optional: override default API endpoint
# NASA_FIRMS_API_URL=https://firms.modaps.eosdis.nasa.gov/api

# ── USGS Earthquake Catalog ────────────────────────────────
# No authentication required — data is public domain (USGov).
# Minimum magnitude threshold to filter noise (0.0–10.0, default 2.5)
USGS_EARTHQUAKE_MIN_MAGNITUDE=2.5
# Optional: override default API endpoint
# USGS_EARTHQUAKE_API_URL=https://earthquake.usgs.gov/fdsnws/event/1

# ── NASA EONET (Earth Observatory Natural Event Tracker) ────
# No authentication required — tracks wildfires, severe storms, volcanoes, etc.
# Number of days to look back when fetching open events
NASA_EONET_DAYS_LOOKBACK=30
# Optional: override default API endpoint
# NASA_EONET_API_URL=https://eonet.gsfc.nasa.gov/api/v3

# ── Open-Meteo Weather Forecast ─────────────────────────────
# No authentication required (CC BY 4.0). Free for non-commercial use.
# Number of hours to average per forecast query
OPEN_METEO_FORECAST_HOURS=6
# Optional: override default API endpoint
# OPEN_METEO_API_URL=https://api.open-meteo.com/v1

# ── NGA Maritime Safety Information ─────────────────────────
# No authentication required — US Gov public domain data.
# Comma-separated NAVAREA codes (IX = Persian Gulf/Red Sea, III = Mediterranean)
NGA_MSI_DEFAULT_NAV_AREAS=IX,III
# Optional: override default API endpoint
# NGA_MSI_API_URL=https://msi.nga.mil/api/publications/broadcast-warn

# ── NOAA Space Weather Prediction Center ────────────────────
# No authentication required — tracks solar flares, geomagnetic storms, etc.
# Optional: override default API endpoint
# NOAA_SWPC_API_URL=https://services.swpc.noaa.gov

# ── OpenAQ Air Quality ──────────────────────────────────────
# API key is REQUIRED for the hosted OpenAQ v3 API (https://api.openaq.org).
# Without a key, requests to the hosted API will be rejected (401).
# Register and obtain a free key at: https://explore.openaq.org/register
# Rate limits: 60/min, 2,000/hour (as of last verification).
OPENAQ_API_KEY=
# Optional: override default API endpoint
# OPENAQ_API_URL=https://api.openaq.org/v3

# ── OSM Overpass (Military Features) ────────────────────────
# No authentication required — ODbL license.
# Optional: override default Overpass API endpoint
# OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter

# ── RapidAPI AIS (Generic bbox AIS endpoint) ────────────────
# RapidAPI subscription key required: https://rapidapi.com/hub
RAPID_API_KEY=
# X-RapidAPI-Host header value for the generic AIS endpoint
RAPID_API_HOST=ais-hub.p.rapidapi.com
# Polling interval in seconds
RAPID_API_POLL_INTERVAL=300
# Default bounding box for Arabian Gulf (south, west, north, east)
RAPID_API_SOUTH=24.5
RAPID_API_WEST=55.5
RAPID_API_NORTH=27.5
RAPID_API_EAST=60.5

# ── VesselData API (vessel-data.p.rapidapi.com) ─────────────
# RapidAPI subscription key required: https://rapidapi.com/hub
VESSEL_DATA_API_KEY=
# Polling interval in seconds
VESSEL_DATA_POLL_INTERVAL=60
# Default bounding box for Strait of Hormuz (south, west, north, east)
VESSEL_DATA_SOUTH=24.5
VESSEL_DATA_WEST=55.5
VESSEL_DATA_NORTH=27.5
VESSEL_DATA_EAST=60.5

# ════════════════════════════════════════════════════════════
# Phase 5: Production Hardening Settings
# ════════════════════════════════════════════════════════════

# ── P5-1: Advanced Caching TTLs (seconds) ───────────────────
# Fine-grained cache TTLs for different query types (beyond base CACHE_TTL_SECONDS)
CACHE_TTL_TIMELINE_SECONDS=300
CACHE_TTL_STAC_SECONDS=900
CACHE_TTL_PLAYBACK_SECONDS=120
CACHE_TTL_SOURCE_HEALTH_SECONDS=60

# ── P5-1.5: Server-Side Density Reduction ───────────────────
# When event search returns more than this threshold, apply subsampling
EVENTS_DENSITY_THRESHOLD=500
# Maximum results to return after density reduction
EVENTS_DENSITY_MAX_RESULTS=200

# ── P5-2.4: Per-Provider Hourly Rate Caps ───────────────────
# Hard caps for external API requests per hour (0 = unlimited)
AISSTREAM_MAX_REQUESTS_PER_HOUR=0
OPENSKY_MAX_REQUESTS_PER_HOUR=60
PLANET_MAX_REQUESTS_PER_HOUR=200

# ── P5-3.2: Freshness SLA Defaults (minutes) ────────────────
# Maximum allowed age for cached data before considering it stale
SLA_GDELT_MAX_AGE_MINUTES=30
SLA_OPENSKY_MAX_AGE_MINUTES=5
SLA_AISSTREAM_MAX_AGE_MINUTES=5
SLA_SENTINEL2_MAX_AGE_MINUTES=60
SLA_LANDSAT_MAX_AGE_MINUTES=120

# ── P5-4.4: Automated Data Retention Enforcement ────────────
# Enable automatic telemetry retention via Celery beat
RETENTION_ENFORCEMENT_ENABLED=true
# Celery beat interval for retention enforcement job (seconds)
RETENTION_ENFORCEMENT_INTERVAL_SECONDS=3600

# ════════════════════════════════════════════════════════════
# Load Testing Configuration (Locust)
# ════════════════════════════════════════════════════════════
# Optional: override API key and AOI ID for load testing scenarios
# LOCUST_API_KEY=
# LOCUST_AOI_ID=test-aoi-1
